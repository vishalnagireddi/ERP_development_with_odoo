<odoo>
    <record id="view_project_form_inherit_ext" model="ir.ui.view">
        <field name="name">project.project.form.inherit.ext</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="assignee_ids" widget="Many2many_tags"/>
                </xpath>
            <!-- Insert above the notebook (tabbed section) -->
            <xpath expr="//notebook" position="before">
                <group col="2">

                <!-- Project Details -->
                    <group string="Project Details" name="custom_project_details" col="2">
                        <field name="project_type"/>
                        <field name="project_id"/>
                        <field name="location"/>
                        <field name="priority"/>
                        <field name="practice"/>
                    </group>



                    <!-- AIO Fields -->
                    <group  string="AIO details" invisible="project_type != 'aio'" >
                        <field name="scope"/>
                        <field name="kick_off_date"/>
                        <field name="go_live_date"/>
                        <field name="client_stakeholders"/>
                        <field name="internal_stakeholders"/>
                        <field name="project_phase"/>
                    </group>

                    <!-- AMS Fields -->
                    <group  string="AMS Fields" invisible="project_type != 'ams'" >
                        <field name="support_start_date"/>
                        <field name="support_end_date"/>
                        <field name="monthly_hours_committed"/>
                        <field name="ticket_tool_used"/>
                        <field name="account_manager"/>
                        <field name="renewal_due"/>
                    </group>
                </group>



            </xpath>
        </field>
    </record>
</odoo>
